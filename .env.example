# Base URL of the deployed Google Apps Script Web App (ends with /exec).
# When empty, the app runs in MOCK mode with built-in demo data — useful for
# local dev and the first Vercel deploy before the Sheets backend is wired.
NUXT_PUBLIC_API_BASE_URL=

# Shared secret sent as `token` to the Apps Script backend (optional but
# recommended). Must match SCRIPT_TOKEN in the Apps Script project.
NUXT_PUBLIC_API_TOKEN=

# Passcode for the login screen in MOCK/demo mode only (default: cineasta).
# In live mode the password is verified server-side (SCRIPT_PASSWORD in Apps
# Script) and this value is ignored.
NUXT_PUBLIC_APP_PASSCODE=cineasta
